MONGO_URI=mongodb://localhost:27017/
DB_NAME=stem_steam_education

# Required for stable auth across restarts
JWT_SECRET=replace-with-a-long-random-secret

# Required for admin login (/admin-login -> /api/admin/login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Contact mail (SMTP / Gmail App Password)
# If MAIL_SERVICE is set (e.g. gmail), MAIL_HOST can be left empty.
MAIL_SERVICE=gmail
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Smart Steam Contact <no-reply@smartsteam.vn>"
CONTACT_EMAIL_TO=
