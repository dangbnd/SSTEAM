# ===========================================================================
# SSTEAM — Environment Configuration
# ===========================================================================
# Copy this file to .env and fill in the values.
# In production (Render), set these as Environment Variables in the dashboard.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
# Set to 'production' on Render; leave unset or 'development' locally
NODE_ENV=development

# Port — Render sets this automatically; locally defaults to 8080
PORT=8080

# ---------------------------------------------------------------------------
# MongoDB  (REQUIRED)
# ---------------------------------------------------------------------------
# Local development
MONGO_URI=mongodb://localhost:27017/
DB_NAME=stem_steam_education

# Production (MongoDB Atlas) — example:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# DB_NAME=stem_steam_education

# ---------------------------------------------------------------------------
# Authentication  (REQUIRED in production)
# ---------------------------------------------------------------------------
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# ---------------------------------------------------------------------------
# Admin credentials  (REQUIRED for admin login)
# ---------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# ---------------------------------------------------------------------------
# Media / Persistent Disk  (REQUIRED on Render)
# ---------------------------------------------------------------------------
# On Render with a persistent disk mounted at /opt/render/media:
# MEDIA_ROOT=/opt/render/media
#
# Locally this defaults to ./media (project root). No change needed for dev.
MEDIA_ROOT=

# ---------------------------------------------------------------------------
# CORS — additional allowed origins (comma-separated)
# ---------------------------------------------------------------------------
# Add your production domain here, e.g.:
# CORS_ORIGIN=https://smartsteam.vn,https://www.smartsteam.vn
CORS_ORIGIN=

# ---------------------------------------------------------------------------
# Google OAuth  (optional — login with Google)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# ---------------------------------------------------------------------------
# Contact Email — SMTP / Gmail App Password  (optional)
# ---------------------------------------------------------------------------
# If MAIL_SERVICE is set (e.g. gmail), MAIL_HOST can be left empty.
MAIL_SERVICE=gmail
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Smart Steam Contact <no-reply@smartsteam.vn>"
CONTACT_EMAIL_TO=


MONGO_URI=mongodb://localhost:27017/
DB_NAME=stem_steam_education